# RetireSim Production Environment
# Copy to .env on the server and fill in real values
# NEVER commit .env to git

# Django
DJANGO_SETTINGS_MODULE=retirement_planner.settings.production
SECRET_KEY=<generate: python3 -c "import secrets; print(secrets.token_urlsafe(50))">
DEBUG=False
ALLOWED_HOSTS=retire.barrettafamily.com
SITE_URL=https://retire.barrettafamily.com

# Database (matches docker-compose db service)
DB_NAME=retirement_planner
DB_USER=rp_user
DB_PASSWORD=<generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))">
DB_HOST=db
DB_PORT=5432

# Redis / Celery (matches docker-compose redis service)
REDIS_URL=redis://redis:6379/0

# Email — Mailgun
MAILGUN_API_KEY=<from Mailgun dashboard>
MAILGUN_SENDER_DOMAIN=barrettafamily.com
DEFAULT_FROM_EMAIL=no-reply@barrettafamily.com

# Sentry (optional — leave blank to skip)
SENTRY_DSN=

# CORS (leave blank unless mobile app)
CORS_ALLOWED_ORIGINS=

# Invite link expiry
INVITATION_EXPIRY_DAYS=7
