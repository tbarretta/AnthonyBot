# Copy this to .env and fill in values
# Never commit .env to git

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_SETTINGS_MODULE=giftregistry.settings.dev
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=giftregistry
DB_USER=giftregistry
DB_PASSWORD=devpassword
DB_HOST=db
DB_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Mailgun
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxx
MAILGUN_SENDER_DOMAIN=mg.yourdomain.com
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Storage (Cloudflare R2 or AWS S3 — same interface)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=giftregistry-media
AWS_S3_ENDPOINT_URL=          # Set for R2: https://<account>.r2.cloudflarestorage.com
AWS_S3_REGION_NAME=auto       # 'auto' for R2, e.g. 'us-east-1' for S3

# App
SITE_URL=http://localhost:8000
MASTER_ADMIN_EMAIL=tom@yourdomain.com
