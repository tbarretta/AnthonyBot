{
  "name": "splittimer",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.15.6",
    "@react-navigation/native": "^7.1.34",
    "@react-navigation/stack": "^7.8.6",
    "expo": "^52.0.49",
    "expo-av": "~15.0.2",
    "expo-haptics": "~14.0.1",
    "expo-sharing": "~13.0.1",
    "expo-sqlite": "~15.1.4",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-audio-record": "^0.2.2",
    "react-native-csv": "^0.2.0",
    "react-native-iap": "^14.7.17",
    "react-native-mmkv": "^4.3.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.11",
    "typescript": "~5.9.2"
  },
  "jest": {
    "projects": [
      {
        "displayName": "unit",
        "testEnvironment": "node",
        "testMatch": [
          "<rootDir>/src/__tests__/**/*.test.ts"
        ],
        "transform": {
          "^.+\\.tsx?$": [
            "babel-jest",
            {
              "presets": [
                "@babel/preset-typescript"
              ],
              "plugins": [
                "@babel/plugin-transform-modules-commonjs"
              ]
            }
          ]
        }
      }
    ]
  },
  "private": true
}
